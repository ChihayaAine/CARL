# Copy to .env and fill in. All values are optional;
# without OPENAI_API_KEY the deterministic mock backend is used.

# OpenAI-compatible endpoint. Works with OpenAI, OpenRouter, vLLM, together,
# fireworks, anyscale, deepinfra, etc.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Model identifier. Pick the open-weight checkpoint your endpoint serves.
MODEL_NAME=mock-model

# Optional: requests/min limit applied to the LLM backend.
LLM_RPM=600

# Optional: HuggingFace datasets cache directory.
HF_DATASETS_CACHE=./data/hf_cache

# Optional: per-task reference budgets used to normalize cost terms.
# Defaults are documented in configs/default.yaml.
REF_TOK_BUDGET_MATH=2000
REF_TOK_BUDGET_QA=3000
REF_TOK_BUDGET_CODE=20000
REF_LAT_BUDGET_MATH=30
REF_LAT_BUDGET_QA=30
REF_LAT_BUDGET_CODE=120
